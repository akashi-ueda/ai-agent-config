{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/caveman.py SessionStart",
            "timeout": 10,
            "statusMessage": "Loading caveman mode"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python hooks/caveman.py UserPromptSubmit",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
