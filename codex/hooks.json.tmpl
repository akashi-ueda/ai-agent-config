{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"{{CODEX_HOME}}/hooks/caveman.py\" SessionStart",
            "timeout": 10,
            "statusMessage": "Loading caveman mode"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"{{PYTHON}}\" \"{{CODEX_HOME}}/hooks/caveman.py\" UserPromptSubmit",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "AGENT_ATTRIBUTION_LOCALE=ko \"{{PYTHON}}\" \"{{CODEX_HOME}}/hooks/attribution_reminder.py\"",
            "timeout": 5,
            "statusMessage": "attribution reminder"
          }
        ]
      }
    ]
  }
}
