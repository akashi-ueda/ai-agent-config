# Copy to repo root as `.env` (gitignored) and fill real values. install reads it.
# These are also exported to your OS user environment by install.

# GitHub PAT for github MCP (fine-grained; repos/issues/pull_requests read).
GITHUB_PERSONAL_ACCESS_TOKEN=

# Obsidian Local REST API token (from Obsidian "Local REST API" plugin).
OBSIDIAN_API_TOKEN=

# Obsidian vault absolute path (per machine).
#   Windows e.g. C:\Users\<you>\Documents\Obsidian Vault
#   macOS   e.g. /Users/<you>/Documents/Obsidian Vault
OBSIDIAN_VAULT_PATH=
